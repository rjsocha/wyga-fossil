# Build artifacts (generated by ./configure and make)
/Makefile
/autoconfig.h
/config.log
/compile_commands.json
/bld/

# Output binary (fork: APPNAME=wyga-fossil)
/wyga-fossil
/wyga-fossil.exe
/wyga-fossil.dSYM/
# Keep the upstream name ignored too in case someone reverts APPNAME
/fossil
/fossil.exe
/fossil.dSYM/

# Bootstrap Tcl interpreter compiled by autosetup when host has no tclsh
/jimsh0

# Common dev clutter
*.o
*.obj
*.bak
*.swp
*.tmp
.DS_Store

# Editor
.vscode/
.idea/
*.iml

# Test repos people sometimes leave behind in the tree
*.fossil-journal
*.fossil-shm
*.fossil-wal

# Personal learning notes (not part of the project)
/LEARNING.md
/SKILL.ROADMAP.md
